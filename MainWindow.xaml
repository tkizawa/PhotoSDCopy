<Window x:Class="PhotoSDCopy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SDカードコピーツール" Height="500" Width="600"
        FontFamily="Meiryo UI" FontSize="14">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <GroupBox Header="入力設定" Grid.Row="0" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="コピー元 (SDカードのドライブ):" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,5"/>
                <TextBox x:Name="SourceTextBox" Grid.Row="1" Grid.Column="0" Margin="0,0,10,15" VerticalContentAlignment="Center" Height="30"/>
                <Button x:Name="SourceBrowseButton" Content="参照" Grid.Row="1" Grid.Column="1" Width="80" Height="30" Margin="0,0,0,15" Click="SourceBrowseButton_Click"/>
                
                <TextBlock Text="コピー先フォルダ:" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,5"/>
                <TextBox x:Name="DestTextBox" Grid.Row="3" Grid.Column="0" Margin="0,0,10,0" VerticalContentAlignment="Center" Height="30"/>
                <Button x:Name="DestBrowseButton" Content="参照" Grid.Row="3" Grid.Column="1" Width="80" Height="30" Click="DestBrowseButton_Click"/>
            </Grid>
        </GroupBox>
        
        <Button x:Name="ExecuteButton" Content="実行" Grid.Row="1" Width="150" Height="40" Margin="0,10,0,10" Click="ExecuteButton_Click"/>
        
        <ProgressBar x:Name="CopyProgressBar" Grid.Row="2" Height="25" Margin="0,10,0,10"/>
        
        <GroupBox Header="処理ログ" Grid.Row="3">
            <TextBox x:Name="LogTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="5"/>
        </GroupBox>
    </Grid>
</Window>
